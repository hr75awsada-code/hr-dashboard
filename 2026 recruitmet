<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard สรรหาบุคลากร 2569</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Sarabun', sans-serif; background: #f5f5f3; color: #1a1a18; min-height: 100vh; padding: 24px; }
@import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@400;500;600&display=swap');
.dash { max-width: 1200px; margin: 0 auto; }
.header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 12px; background: #fff; border-radius: 12px; padding: 20px 24px; border: 0.5px solid #e2e2de; }
.header-title { font-size: 20px; font-weight: 600; color: #1a1a18; }
.header-sub { font-size: 13px; color: #73726c; margin-top: 3px; }
.controls { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
select, input[type=text] { font-size: 13px; padding: 7px 12px; border: 0.5px solid #d3d1c7; border-radius: 8px; background: #fff; color: #1a1a18; outline: none; cursor: pointer; }
select:hover, input[type=text]:hover { border-color: #888780; }
.upload-btn { font-size: 13px; padding: 7px 16px; border: 0.5px solid #d3d1c7; border-radius: 8px; background: #fff; color: #1a1a18; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: background 0.15s; }
.upload-btn:hover { background: #f1efe8; }
.file-input-wrap { position: relative; }
.file-input-wrap input[type=file] { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; }
.metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin-bottom: 16px; }
.metric { background: #fff; border-radius: 10px; padding: 16px 18px; border: 0.5px solid #e2e2de; }
.metric-label { font-size: 12px; color: #73726c; margin-bottom: 6px; }
.metric-value { font-size: 26px; font-weight: 600; color: #1a1a18; }
.metric-sub { font-size: 11px; color: #888780; margin-top: 4px; }
.charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.chart-card { background: #fff; border: 0.5px solid #e2e2de; border-radius: 12px; padding: 20px; }
.chart-title { font-size: 14px; font-weight: 600; color: #1a1a18; margin-bottom: 12px; }
.legend { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 10px; font-size: 12px; color: #73726c; }
.legend span { display: flex; align-items: center; gap: 5px; }
.legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
.table-section { background: #fff; border: 0.5px solid #e2e2de; border-radius: 12px; padding: 20px; margin-top: 0; }
.table-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; flex-wrap: wrap; gap: 10px; }
.filter-row { display: flex; gap: 8px; flex-wrap: wrap; }
.filter-row select, .filter-row input { font-size: 12px; padding: 5px 10px; }
.tbl-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 12px; table-layout: fixed; }
th { font-size: 11px; font-weight: 600; color: #73726c; text-align: left; padding: 8px 10px; border-bottom: 1px solid #e2e2de; cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; background: #f9f9f7; }
th:hover { color: #1a1a18; background: #f1efe8; }
td { padding: 7px 10px; border-bottom: 0.5px solid #f1efe8; color: #1a1a18; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
tr:last-child td { border-bottom: none; }
tr:hover td { background: #f9f9f7; }
.badge { display: inline-block; font-size: 11px; padding: 2px 10px; border-radius: 20px; font-weight: 500; }
.badge-work { background: #EAF3DE; color: #3B6D11; }
.badge-quit { background: #FCEBEB; color: #A32D2D; }
.badge-fire { background: #FAEEDA; color: #854F0B; }
.pagination { display: flex; align-items: center; gap: 8px; margin-top: 14px; font-size: 12px; color: #73726c; }
.page-btn { font-size: 13px; padding: 4px 14px; border: 0.5px solid #d3d1c7; border-radius: 6px; background: #fff; cursor: pointer; }
.page-btn:hover { background: #f1efe8; }
.sort-arrow { font-size: 10px; margin-left: 2px; }
@media (max-width: 700px) {
  .charts-row { grid-template-columns: 1fr; }
  body { padding: 12px; }
}
</style>
</head>
<body>
<div class="dash">
  <div class="header">
    <div>
      <div class="header-title">📊 Dashboard สรรหาบุคลากร 2569</div>
      <div class="header-sub">มกราคม – พฤษภาคม 2569 | สามารถอัปโหลด CSV เพื่อโหลดข้อมูลใหม่ได้</div>
    </div>
    <div class="controls">
      <select id="monthFilter" onchange="applyFilters()">
        <option value="all">ทุกเดือน</option>
        <option value="มกราคม">มกราคม</option>
        <option value="กุมภาพันธ์">กุมภาพันธ์</option>
        <option value="มีนาคม">มีนาคม</option>
        <option value="เมษายน">เมษายน</option>
        <option value="พฤษภาคม">พฤษภาคม</option>
        <option value="มิถุนายน">มิถุนายน</option>
        <option value="กรกฎาคม">กรกฎาคม</option>
        <option value="สิงหาคม">สิงหาคม</option>
        <option value="กันยายน">กันยายน</option>
        <option value="ตุลาคม">ตุลาคม</option>
        <option value="พฤศจิกายน">พฤศจิกายน</option>
        <option value="ธันวาคม">ธันวาคม</option>
      </select>
      <div class="file-input-wrap">
        <button class="upload-btn"><i class="ti ti-upload"></i> นำเข้า CSV</button>
        <input type="file" accept=".csv" onchange="loadCSV(event)">
      </div>
      <button class="upload-btn" onclick="fetchFromSheets()" title="รีเฟรชข้อมูลจาก Google Sheets"><i class="ti ti-refresh"></i> รีเฟรช</button>
    </div>
  </div>
  <div style="font-size:12px;color:#73726c;margin-bottom:12px;padding:0 2px;" id="syncStatus">⏳ กำลังโหลดข้อมูล...</div>

  <div class="metrics" id="metrics"></div>

  <div class="charts-row">
    <div class="chart-card">
      <div class="chart-title">จำนวนรับสมัครรายเดือน</div>
      <div class="legend">
        <span><span class="legend-dot" style="background:#378ADD"></span>รับเข้า</span>
        <span><span class="legend-dot" style="background:#E24B4A"></span>ลาออก/เลิกจ้าง</span>
        <span><span class="legend-dot" style="background:#1D9E75"></span>ทำงานอยู่</span>
      </div>
      <div style="position:relative;width:100%;height:260px;">
        <canvas id="barChart"></canvas>
      </div>
    </div>
    <div class="chart-card">
      <div class="chart-title">เปรียบเทียบทำงานอยู่ vs ลาออก/เลิกจ้าง</div>
      <div class="legend">
        <span><span class="legend-dot" style="background:#1D9E75"></span>ทำงานอยู่</span>
        <span><span class="legend-dot" style="background:#E24B4A"></span>ลาออก/เลิกจ้าง</span>
      </div>
      <div style="position:relative;width:100%;height:260px;">
        <canvas id="retainChart"></canvas>
      </div>
    </div>
  </div>

  <div class="charts-row">
    <div class="chart-card">
      <div class="chart-title">สัดส่วนตามสังกัด</div>
      <div class="legend" id="branchLegend"></div>
      <div style="position:relative;width:100%;height:230px;">
        <canvas id="branchPie"></canvas>
      </div>
    </div>
    <div class="chart-card">
      <div class="chart-title">ช่องทางการสรรหา</div>
      <div class="legend" id="sourceLegend"></div>
      <div style="position:relative;width:100%;height:230px;">
        <canvas id="sourcePie"></canvas>
      </div>
    </div>
  </div>

  <div class="chart-card" style="margin-bottom:16px;">
    <div class="chart-title">พนักงานรายแผนก</div>
    <div class="legend">
      <span><span class="legend-dot" style="background:#378ADD"></span>ทำงานอยู่</span>
      <span><span class="legend-dot" style="background:#E24B4A"></span>ลาออก/เลิกจ้าง</span>
    </div>
    <div style="position:relative;width:100%;height:520px;">
      <canvas id="deptChart"></canvas>
    </div>
  </div>

  <div class="table-section">
    <div class="table-header">
      <div style="font-size:15px;font-weight:600;color:#1a1a18">ข้อมูลพนักงานทั้งหมด</div>
      <div class="filter-row">
        <input type="text" id="searchName" placeholder="ค้นหาชื่อ / ชื่อเล่น..." oninput="applyFilters()" style="min-width:160px">
        <select id="filterBranch" onchange="applyFilters()"><option value="">ทุกสังกัด</option></select>
        <select id="filterDept" onchange="applyFilters()"><option value="">ทุกแผนก</option></select>
        <select id="filterStatus" onchange="applyFilters()">
          <option value="">ทุกสถานะ</option>
          <option value="ทำงาน">ทำงาน</option>
          <option value="ลาออก">ลาออก</option>
          <option value="เลิกจ้าง">เลิกจ้าง</option>
        </select>
        <select id="filterSource" onchange="applyFilters()"><option value="">ทุกช่องทาง</option></select>
        <select id="filterGender" onchange="applyFilters()">
          <option value="">ทุกเพศ</option>
          <option value="M">ชาย</option>
          <option value="F">หญิง</option>
        </select>
      </div>
    </div>
    <div class="tbl-wrap">
      <table id="empTable">
        <thead>
          <tr>
            <th style="width:40px" onclick="sortTable('idx')">#<span class="sort-arrow" id="sort-idx"></span></th>
            <th style="width:55px" onclick="sortTable('branch')">สังกัด<span class="sort-arrow" id="sort-branch"></span></th>
            <th style="width:100px" onclick="sortTable('dept')">แผนก<span class="sort-arrow" id="sort-dept"></span></th>
            <th style="width:95px" onclick="sortTable('code')">รหัส<span class="sort-arrow" id="sort-code"></span></th>
            <th style="width:170px" onclick="sortTable('name')">ชื่อ-นามสกุล<span class="sort-arrow" id="sort-name"></span></th>
            <th style="width:65px" onclick="sortTable('nick')">ชื่อเล่น<span class="sort-arrow" id="sort-nick"></span></th>
            <th style="width:170px" onclick="sortTable('pos')">ตำแหน่ง<span class="sort-arrow" id="sort-pos"></span></th>
            <th style="width:40px" onclick="sortTable('level')">Lv<span class="sort-arrow" id="sort-level"></span></th>
            <th style="width:50px" onclick="sortTable('gender')">เพศ<span class="sort-arrow" id="sort-gender"></span></th>
            <th style="width:85px" onclick="sortTable('status')">สถานะ<span class="sort-arrow" id="sort-status"></span></th>
            <th style="width:95px" onclick="sortTable('start')">เริ่มงาน<span class="sort-arrow" id="sort-start"></span></th>
            <th style="width:95px" onclick="sortTable('end')">วันที่ลาออก<span class="sort-arrow" id="sort-end"></span></th>
            <th style="width:80px" onclick="sortTable('month')">เดือน<span class="sort-arrow" id="sort-month"></span></th>
            <th style="width:110px" onclick="sortTable('source')">ช่องทาง<span class="sort-arrow" id="sort-source"></span></th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
    <div class="pagination">
      <button class="page-btn" onclick="changePage(-1)">‹ ก่อนหน้า</button>
      <span id="pageInfo"></span>
      <button class="page-btn" onclick="changePage(1)">ถัดไป ›</button>
      <span style="margin-left:auto;color:#888780" id="rowCount"></span>
    </div>
  </div>
</div>

<script>
// ============================================================
// Google Sheets real-time config
// ============================================================
const CSV_URL = 'https://script.google.com/macros/s/AKfycbz4HNsTuDUwZ33W4VVdpwIDwfDSIo0AiZeBgqJKM4pz3MMlPFLsXEOzyz1hIgEYeQQPZw/exec';
const REFRESH_INTERVAL = 5 * 60 * 1000; // รีเฟรชทุก 5 นาที

let allData = [];
let filteredData = [];
let currentPage = 1;
const perPage = 15;
let sortKey = 'idx';
let sortDir = 1;
let charts = {};

const MONTHS = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
const PIE_COLORS = ['#378ADD','#1D9E75','#E24B4A','#BA7517','#9F77DD','#D4537E','#639922','#5F5E5A'];

function getFiltered() {
  const month = document.getElementById('monthFilter').value;
  const branch = document.getElementById('filterBranch').value;
  const dept = document.getElementById('filterDept').value;
  const status = document.getElementById('filterStatus').value;
  const source = document.getElementById('filterSource').value;
  const gender = document.getElementById('filterGender').value;
  const search = (document.getElementById('searchName').value || '').toLowerCase();
  return allData.filter(r =>
    (month === 'all' || r.month === month) &&
    (!branch || r.branch === branch) &&
    (!dept || r.dept === dept) &&
    (!status || r.status === status) &&
    (!source || r.source === source) &&
    (!gender || r.gender === gender) &&
    (!search || r.name.toLowerCase().includes(search) || r.nick.toLowerCase().includes(search))
  );
}

function applyFilters() {
  filteredData = getFiltered();
  currentPage = 1;
  renderMetrics(filteredData);
  renderCharts(filteredData);
  renderTable();
}

function renderMetrics(data) {
  const total = data.length;
  const working = data.filter(r => r.status === 'ทำงาน').length;
  const quit = data.filter(r => r.status === 'ลาออก').length;
  const fired = data.filter(r => r.status === 'เลิกจ้าง').length;
  const retention = total > 0 ? Math.round(working / total * 100) : 0;
  document.getElementById('metrics').innerHTML = `
    <div class="metric"><div class="metric-label">รับเข้าทั้งหมด</div><div class="metric-value">${total}</div><div class="metric-sub">คน</div></div>
    <div class="metric"><div class="metric-label">ทำงานอยู่</div><div class="metric-value" style="color:#1D9E75">${working}</div><div class="metric-sub">คน</div></div>
    <div class="metric"><div class="metric-label">ลาออก</div><div class="metric-value" style="color:#E24B4A">${quit}</div><div class="metric-sub">คน</div></div>
    <div class="metric"><div class="metric-label">เลิกจ้าง</div><div class="metric-value" style="color:#BA7517">${fired}</div><div class="metric-sub">คน</div></div>
    <div class="metric"><div class="metric-label">อัตราคงอยู่</div><div class="metric-value">${retention}%</div><div class="metric-sub">retention rate</div></div>
  `;
}

function getMonthsInData(data) {
  const s = new Set(data.map(r => r.month));
  return MONTHS.filter(m => s.has(m));
}

function renderCharts(data) {
  const months = getMonthsInData(data);
  const totalByM = months.map(m => data.filter(r => r.month === m).length);
  const workByM = months.map(m => data.filter(r => r.month === m && r.status === 'ทำงาน').length);
  const quitByM = months.map(m => data.filter(r => r.month === m && (r.status === 'ลาออก' || r.status === 'เลิกจ้าง')).length);

  if (charts.bar) charts.bar.destroy();
  charts.bar = new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
      labels: months,
      datasets: [
        { label: 'รับเข้า', data: totalByM, backgroundColor: '#378ADD', borderRadius: 4 },
        { label: 'ลาออก/เลิกจ้าง', data: quitByM, backgroundColor: '#E24B4A', borderRadius: 4 },
        { label: 'ทำงานอยู่', data: workByM, backgroundColor: '#1D9E75', borderRadius: 4 },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      onClick: (e, els) => { if (els.length) { const m = months[els[0].index]; document.getElementById('monthFilter').value = m; applyFilters(); } },
      plugins: { legend: { display: false }, tooltip: { mode: 'index' } },
      scales: { x: { ticks: { autoSkip: false } }, y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
  });

  if (charts.retain) charts.retain.destroy();
  charts.retain = new Chart(document.getElementById('retainChart'), {
    type: 'line',
    data: {
      labels: months,
      datasets: [
        { label: 'ทำงานอยู่', data: workByM, borderColor: '#1D9E75', backgroundColor: 'rgba(29,158,117,0.1)', fill: true, tension: 0.3, pointRadius: 5 },
        { label: 'ลาออก/เลิกจ้าง', data: quitByM, borderColor: '#E24B4A', borderDash: [5,3], backgroundColor: 'rgba(226,75,74,0.05)', fill: true, tension: 0.3, pointRadius: 5 },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      onClick: (e, els) => { if (els.length) { const m = months[els[0].index]; document.getElementById('monthFilter').value = m; applyFilters(); } },
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
  });

  const branches = [...new Set(data.map(r => r.branch))];
  const branchCounts = branches.map(b => data.filter(r => r.branch === b).length);
  document.getElementById('branchLegend').innerHTML = branches.map((b, i) => `<span><span class="legend-dot" style="background:${PIE_COLORS[i % PIE_COLORS.length]}"></span>${b} (${branchCounts[i]})</span>`).join('');
  if (charts.branch) charts.branch.destroy();
  charts.branch = new Chart(document.getElementById('branchPie'), {
    type: 'pie',
    data: { labels: branches, datasets: [{ data: branchCounts, backgroundColor: PIE_COLORS, hoverOffset: 8 }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      onClick: (e, els) => { if (els.length) { document.getElementById('filterBranch').value = branches[els[0].index]; applyFilters(); } },
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${ctx.label}: ${ctx.raw} คน (${Math.round(ctx.raw/data.length*100)}%)` } } }
    }
  });

  const sources = [...new Set(data.map(r => r.source))];
  const srcCounts = sources.map(s => data.filter(r => r.source === s).length);
  document.getElementById('sourceLegend').innerHTML = sources.map((s, i) => `<span><span class="legend-dot" style="background:${PIE_COLORS[(i+3) % PIE_COLORS.length]}"></span>${s} (${srcCounts[i]})</span>`).join('');
  if (charts.source) charts.source.destroy();
  charts.source = new Chart(document.getElementById('sourcePie'), {
    type: 'pie',
    data: { labels: sources, datasets: [{ data: srcCounts, backgroundColor: PIE_COLORS.slice(3).concat(PIE_COLORS), hoverOffset: 8 }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      onClick: (e, els) => { if (els.length) { document.getElementById('filterSource').value = sources[els[0].index]; applyFilters(); } },
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${ctx.label}: ${ctx.raw} คน (${Math.round(ctx.raw/data.length*100)}%)` } } }
    }
  });

  const depts = [...new Set(data.map(r => r.dept))].sort((a,b) => {
    return data.filter(r=>r.dept===b).length - data.filter(r=>r.dept===a).length;
  });
  const deptWork = depts.map(d => data.filter(r=>r.dept===d&&r.status==='ทำงาน').length);
  const deptLeft = depts.map(d => data.filter(r=>r.dept===d&&(r.status==='ลาออก'||r.status==='เลิกจ้าง')).length);
  const deptH = Math.max(400, depts.length * 38 + 80);
  document.getElementById('deptChart').parentElement.style.height = deptH + 'px';
  if (charts.dept) charts.dept.destroy();
  charts.dept = new Chart(document.getElementById('deptChart'), {
    type: 'bar',
    data: {
      labels: depts,
      datasets: [
        { label: 'ทำงานอยู่', data: deptWork, backgroundColor: '#378ADD', borderRadius: 3, stack: 'a' },
        { label: 'ลาออก/เลิกจ้าง', data: deptLeft, backgroundColor: '#E24B4A', borderRadius: 3, stack: 'a' },
      ]
    },
    options: {
      indexAxis: 'y',
      responsive: true, maintainAspectRatio: false,
      onClick: (e, els) => { if (els.length) { document.getElementById('filterDept').value = depts[els[0].index]; applyFilters(); } },
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { afterBody: (items) => {
          const d = items[0].label;
          const total = data.filter(r=>r.dept===d).length;
          const w = data.filter(r=>r.dept===d&&r.status==='ทำงาน').length;
          return `รวม: ${total} คน | คงอยู่: ${Math.round(w/total*100)}%`;
        }}}
      },
      scales: {
        x: { stacked: true, beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(136,135,128,0.15)' } },
        y: { stacked: true, ticks: { font: { size: 12 } } }
      }
    }
  });
}

function renderTable() {
  const sorted = [...filteredData].sort((a, b) => {
    let av = a[sortKey], bv = b[sortKey];
    if (typeof av === 'string') av = av.toLowerCase();
    if (typeof bv === 'string') bv = bv.toLowerCase();
    return av < bv ? -sortDir : av > bv ? sortDir : 0;
  });
  const start = (currentPage - 1) * perPage;
  const page = sorted.slice(start, start + perPage);
  document.getElementById('tableBody').innerHTML = page.map(r => `
    <tr>
      <td>${r.idx}</td>
      <td>${r.branch}</td>
      <td>${r.dept}</td>
      <td style="font-family:monospace;font-size:11px">${r.code}</td>
      <td>${r.name}</td>
      <td>${r.nick}</td>
      <td>${r.pos}</td>
      <td style="text-align:center">${r.level}</td>
      <td style="text-align:center">${r.gender === 'M' ? 'ชาย' : 'หญิง'}</td>
      <td><span class="badge ${r.status === 'ทำงาน' ? 'badge-work' : r.status === 'ลาออก' ? 'badge-quit' : 'badge-fire'}">${r.status}</span></td>
      <td>${fmtDate(r.start)}</td>
      <td>${r.end ? fmtDate(r.end) : '-'}</td>
      <td>${r.month}</td>
      <td>${r.source}</td>
    </tr>
  `).join('');
  const totalPages = Math.ceil(filteredData.length / perPage);
  document.getElementById('pageInfo').textContent = `หน้า ${currentPage} / ${Math.max(1, totalPages)}`;
  document.getElementById('rowCount').textContent = `แสดง ${Math.min(start+1, filteredData.length)}–${Math.min(start+perPage, filteredData.length)} จาก ${filteredData.length} รายการ`;
}

function fmtDate(val) {
  if (!val || val.trim() === '' || val === '-') return '-';
  const v = val.trim();
  if (/^\d{1,2}\/\d{1,2}\/\d{4}$/.test(v)) {
    const [d, m, y] = v.split('/');
    return `${String(d).padStart(2,'0')}/${String(m).padStart(2,'0')}/${y}`;
  }
  if (/^\d{4}-\d{2}-\d{2}/.test(v)) {
    const [y, m, d] = v.split('T')[0].split('-');
    return `${d}/${m}/${y}`;
  }
  const gviz = v.match(/Date\((\d{4}),(\d+),(\d+)\)/);
  if (gviz) {
    const y = gviz[1], m = String(parseInt(gviz[2]) + 1).padStart(2,'0'), d = String(gviz[3]).padStart(2,'0');
    return `${d}/${m}/${y}`;
  }
  // รูปแบบ "Mon Jan 05 2026 00:00:00 GMT+0700" จาก Apps Script
  const dt = new Date(v);
  if (!isNaN(dt.getTime())) {
    const d = String(dt.getUTCDate()).padStart(2,'0');
    const m = String(dt.getUTCMonth() + 1).padStart(2,'0');
    const y = dt.getUTCFullYear();
    return `${d}/${m}/${y}`;
  }
  return v;
}

function changePage(dir) {
  const totalPages = Math.ceil(filteredData.length / perPage);
  currentPage = Math.max(1, Math.min(totalPages, currentPage + dir));
  renderTable();
}

function sortTable(key) {
  if (sortKey === key) sortDir *= -1; else { sortKey = key; sortDir = 1; }
  document.querySelectorAll('.sort-arrow').forEach(el => el.textContent = '');
  const el = document.getElementById('sort-' + key);
  if (el) el.textContent = sortDir === 1 ? ' ↑' : ' ↓';
  renderTable();
}

function populateFilters() {
  const branches = [...new Set(allData.map(r => r.branch))].sort();
  const depts = [...new Set(allData.map(r => r.dept))].sort();
  const sources = [...new Set(allData.map(r => r.source))].sort();
  const br = document.getElementById('filterBranch');
  while (br.options.length > 1) br.remove(1);
  branches.forEach(b => { const o = document.createElement('option'); o.value = b; o.textContent = b; br.appendChild(o); });
  const dp = document.getElementById('filterDept');
  while (dp.options.length > 1) dp.remove(1);
  depts.forEach(d => { const o = document.createElement('option'); o.value = d; o.textContent = d; dp.appendChild(o); });
  const sr = document.getElementById('filterSource');
  while (sr.options.length > 1) sr.remove(1);
  sources.forEach(s => { const o = document.createElement('option'); o.value = s; o.textContent = s; sr.appendChild(o); });
}

// ---- parse CSV text → array of row objects ----
function parseCSVText(text) {
  // Handles quoted fields with commas inside
  function splitCSVLine(line) {
    const result = [];
    let cur = '', inQ = false;
    for (let i = 0; i < line.length; i++) {
      const ch = line[i];
      if (ch === '"') { inQ = !inQ; }
      else if (ch === ',' && !inQ) { result.push(cur.trim()); cur = ''; }
      else { cur += ch; }
    }
    result.push(cur.trim());
    return result;
  }
  const lines = text.split('\n').filter(l => l.trim());
  if (lines.length < 2) return [];
  const headers = splitCSVLine(lines[0]).map(h => h.replace(/^"|"$/g, '').trim());
  const get = (cols, names) => {
    for (const n of names) {
      const i = headers.findIndex(h => h.includes(n));
      if (i >= 0) return (cols[i] || '').replace(/^"|"$/g, '').trim();
    }
    return '';
  };
  const parsed = [];
  for (let i = 1; i < lines.length; i++) {
    const cols = splitCSVLine(lines[i]);
    if (cols.length < 5) continue;
    const row = {
      idx: i,
      branch: get(cols, ['สังกัด']),
      dept:   get(cols, ['แผนก']),
      code:   get(cols, ['รหัส']),
      name:   get(cols, ['ชื่อ - นามสกุล', 'ชื่อ-นามสกุล']),
      nick:   get(cols, ['ชื่อเล่น']),
      pos:    get(cols, ['ตำแหน่ง']),
      level:  parseInt(get(cols, ['Level'])) || 0,
      gender: get(cols, ['เพศ']),
      status: get(cols, ['สถานะ']),
      start:  get(cols, ['วันที่เริ่มงาน']),
      end:    get(cols, ['วันที่มีผล', 'วันที่ลาออก']),
      month:  get(cols, ['เดือน']),
      source: get(cols, ['ช่องทาง']),
    };
    if (row.branch || row.name) parsed.push(row);
  }
  return parsed;
}

// ---- fetch from Google Sheets ----
function setStatus(msg, isError) {
  let el = document.getElementById('syncStatus');
  if (!el) return;
  el.textContent = msg;
  el.style.color = isError ? '#A32D2D' : '#3B6D11';
}

function processSheetData(json) {
  const get = (row, names) => {
    for (const n of names) {
      const key = Object.keys(row).find(k => k.includes(n));
      if (key) return (row[key] || '').trim();
    }
    return '';
  };
  allData = json.map((row, i) => ({
    idx: i + 1,
    branch: get(row, ['สังกัด']),
    dept:   get(row, ['แผนก']),
    code:   get(row, ['รหัส']),
    name:   get(row, ['ชื่อ - นามสกุล', 'ชื่อ-นามสกุล']),
    nick:   get(row, ['ชื่อเล่น']),
    pos:    get(row, ['ตำแหน่ง']),
    level:  parseInt(get(row, ['Level'])) || 0,
    gender: get(row, ['เพศ']),
    status: get(row, ['สถานะ']),
    start:  get(row, ['วันที่เริ่มงาน']),
    end:    get(row, ['วันที่มีผล', 'วันที่ลาออก']),
    month:  get(row, ['เดือน']),
    source: get(row, ['ช่องทาง']),
  })).filter(r => r.branch || r.name);

  populateFilters();
  applyFilters();
  const now = new Date().toLocaleTimeString('th-TH');
  setStatus(`✅ อัปเดตล่าสุด: ${now} (${allData.length} รายการ)`, false);
}

// JSONP — ทำงานได้แม้เปิดจาก file://
function fetchFromSheets() {
  setStatus('⏳ กำลังโหลดข้อมูลจาก Google Sheets...', false);

  // ลบ script tag เก่าทิ้งก่อน
  const old = document.getElementById('jsonp-script');
  if (old) old.remove();

  // สร้าง callback unique
  const cbName = 'sheetsCallback_' + Date.now();
  window[cbName] = function(data) {
    delete window[cbName];
    document.getElementById('jsonp-script').remove();
    if (!Array.isArray(data) || data.length === 0) {
      setStatus('❌ ไม่พบข้อมูลในชีต', true);
      return;
    }
    processSheetData(data);
  };

  const script = document.createElement('script');
  script.id = 'jsonp-script';
  script.src = CSV_URL + '?callback=' + cbName;
  script.onerror = () => {
    setStatus('❌ โหลดไม่สำเร็จ กรุณาตรวจสอบ Apps Script URL', true);
    delete window[cbName];
  };
  document.head.appendChild(script);
}

// ---- upload CSV manually ----
function loadCSV(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    const parsed = parseCSVText(ev.target.result);
    if (parsed.length > 0) {
      allData = parsed;
      populateFilters();
      applyFilters();
      setStatus(`✅ โหลดจากไฟล์: ${parsed.length} รายการ`, false);
    } else {
      setStatus('❌ ไม่พบข้อมูลในไฟล์ CSV', true);
    }
  };
  reader.readAsText(file, 'UTF-8');
}

// ---- init ----
fetchFromSheets();
setInterval(fetchFromSheets, REFRESH_INTERVAL);
